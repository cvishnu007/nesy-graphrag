# Source selection: "arxiv" or "s2"
DATA_SOURCE=s2

# Neo4j
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_me

# LLM provider
GROQ_API_KEY=replace_me

# Semantic Scholar (rotate any previously exposed key before using)
SEMANTIC_SCHOLAR_API_KEY=replace_me
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_MIN_INTERVAL_SEC=1.05
SEMANTIC_SCHOLAR_TIMEOUT_SEC=45
SEMANTIC_SCHOLAR_MAX_RETRIES=6
S2_QUERY=graph neural networks
S2_LIMIT=10000
S2_PAGE_SIZE=1000
S2_YEAR=2020-2025
S2_FIELDS_OF_STUDY=Computer Science
S2_PUBLICATION_TYPES=
S2_SORT=citationCount:desc
S2_BATCH_SIZE=500
S2_MAX_REFS_PER_PAPER=200

# Storage paths (leave defaults unless needed)
CHROMA_DIR=./data/chromadb
ARXIV_RAW_FILE=./data/arxiv_raw.json
ARXIV_CLEAN_FILE=./data/arxiv_clean.json
ARXIV_NER_FILE=./data/arxiv_ner.json
S2_RAW_FILE=./data/s2_raw.json
S2_CLEAN_FILE=./data/s2_clean.json
S2_NER_FILE=./data/s2_ner.json

# Optional overrides that follow DATA_SOURCE by default
# RAW_FILE=
# CLEAN_FILE=
# NER_FILE=

CHROMA_COLLECTION=s2_papers
USE_REAL_CITATIONS=true

# Models
EMBEDDING_MODEL=allenai-specter
LLM_MODEL=llama-3.3-70b-versatile

# Pipeline tuning
BATCH_SIZE=64
NEO4J_BATCH_SIZE=500
TOP_K=10
HOP_DEPTH=2
CITES_THRESHOLD=2
MAX_AUTHORS=5
MAX_CONCEPTS=10
MIN_ABSTRACT_WORDS=30
